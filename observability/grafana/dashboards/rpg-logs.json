        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "debug,info,warn,error",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "title": "Log volume by level",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "expr": "sum by (detected_level) (count_over_time({service_name=~\"$service\"} | detected_level=~\"$level\" [$__interval]))", "legendFormat": "{{detected_level}}", "queryType": "range", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "title": "Logs  (open a line → Tempo trace via trace_id)",
