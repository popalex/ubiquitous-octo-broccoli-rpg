APP_NAME=small-rpg-gpt
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/roleplay

# Dev mode: use a single model for actor, memory, and GM to save RAM.
# Set DEV_MODE=true and specify the model with DEV_MODEL_NAME.
DEV_MODE=false
DEV_MODEL_NAME=llama3.2:3b

# Primary local-first setup: Docker Compose runs Ollama for actor, memory, GM, and embeddings.
ACTOR_PROVIDER=ollama
MEMORY_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
GM_PROVIDER=ollama

# Model assignments:
# - Actor: Character dialogue (creative, high quality)
# - GM: Narration, events, NPC orchestration (creative, world-building)
# - Memory: Summaries, fact extraction, continuity checks (precise, deterministic)
ACTOR_MODEL_NAME=llama3.1:8b
MEMORY_MODEL_NAME=phi3:mini
EMBEDDING_MODEL_NAME=nomic-embed-text
GM_MODEL_NAME=llama3.1:8b
EMBEDDING_DIMENSION=768

# Leave these empty unless you explicitly switch a provider to `openai`.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://ollama:11434

RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_POOL=20
RECENCY_HALF_LIFE_HOURS=72
MEMORY_SUMMARY_INTERVAL=6

ACTOR_MAX_INPUT_TOKENS=6000
ACTOR_RESERVED_OUTPUT_TOKENS=500
ACTOR_TEMPERATURE=0.7
CONTINUITY_TEMPERATURE=0.2

# Game Master settings
GM_TEMPERATURE=0.8
GM_MAX_OUTPUT_TOKENS=800
GM_NARRATION_MAX_TOKENS=0
EVENT_CHECK_INTERVAL=3
EVENT_PROBABILITY=0.4

# OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT: where to ship traces/logs/metrics (OTLP gRPC).
#   Leave unset to fully disable telemetry (e.g. local runs without the collector).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4317
OTEL_SERVICE_NAME=rpg-backend
OTEL_RESOURCE_ATTRIBUTES=service.namespace=small-rpg-gpt,deployment.environment=local
# OTEL_CAPTURE_CONTENT: true = full telemetry (capture LLM prompts/completions
#   and user messages on spans). false = metadata only (model, tokens, latency).
OTEL_CAPTURE_CONTENT=false
