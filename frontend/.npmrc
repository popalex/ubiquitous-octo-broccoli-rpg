# Allow pnpm to purge/recreate node_modules without an interactive TTY prompt.
# The dev container mounts node_modules as an anonymous volume that persists
# across runs; when dependencies change the volume goes stale and pnpm must
# recreate it. Without this it aborts with ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY.
confirm-modules-purge=false
